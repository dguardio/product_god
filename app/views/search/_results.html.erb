<div data-controller="results" data-action="typewriter:end->results#reveal">
  <% if @answer %>
    <%# @answer is now a Hash derived from JSON %>
    <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden mb-8">
      
      <!-- Header with Confidence Badge -->
      <div class="p-6 bg-indigo-50 border-b border-indigo-100 flex justify-between items-center">
        <h2 class="text-xl font-semibold text-indigo-900">Answer</h2>
        <% 
           confidence_color = case @answer["confidence"]
             when "high" then "bg-green-100 text-green-800"
             when "medium" then "bg-yellow-100 text-yellow-800"
             else "bg-red-100 text-red-800"
           end 
        %>
        <span class="text-xs font-bold uppercase px-2 py-1 rounded <%= confidence_color %>">
          <%= @answer["confidence"] %> Confidence
        </span>
      </div>

      <div class="p-6 space-y-6">
        <!-- Main Answer -->
        <div class="prose prose-lg max-w-none text-gray-800">
          <p data-controller="typewriter"><%= @answer["answer"] %></p>
        </div>

        <!-- Key Points -->
        <% if @answer["key_points"].present? %>
          <div data-results-target="section">
            <h3 class="font-semibold text-gray-700 mb-2">Key Points</h3>
            <ul class="list-disc pl-5 space-y-1 text-gray-600">
              <% @answer["key_points"].each do |point| %>
                <li><%= point %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <!-- Related Topics -->
        <% if @answer["related_topics"].present? %>
          <div data-results-target="section">
             <h3 class="font-semibold text-gray-700 mb-2 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" /></svg>
                Related Topics
             </h3>
             <div class="flex flex-wrap gap-2">
               <% @answer["related_topics"].each do |topic| %>
                 <span class="bg-gray-100 text-gray-600 px-3 py-1 rounded-full text-sm hover:bg-gray-200 cursor-default">
                   <%= topic %>
                 </span>
               <% end %>
             </div>
          </div>
        <% end %>
        
        <!-- Context Gaps (if any) -->
        <% if @answer["context_gaps"].present? %>
           <div data-results-target="section" class="bg-orange-50 p-4 rounded-lg border border-orange-100">
             <h3 class="text-sm font-semibold text-orange-800 mb-1">Missing Context</h3>
             <ul class="list-disc pl-5 text-sm text-orange-700">
               <% @answer["context_gaps"].each do |gap| %>
                 <li><%= gap %></li>
               <% end %>
             </ul>
           </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @sources.present? %>
    <div data-results-target="section" class="space-y-4">
      <h3 class="text-lg font-semibold text-gray-500 uppercase tracking-wide">Sources</h3>
      
      <% @sources.each do |chunk| %>
        <div class="bg-gray-50 p-4 rounded-lg border border-gray-200 hover:border-indigo-300 transition">
          <p class="text-sm text-gray-800 mb-2 italic">
            "...<%= chunk.content.truncate(300) %>..."
          </p>
          <div class="flex items-center text-xs text-gray-500 font-medium">
            <span class="bg-indigo-100 text-indigo-700 px-2 py-1 rounded mr-2">
              Chunk #<%= chunk.id %>
            </span>
            <% if chunk.respond_to?(:sourceable) && chunk.sourceable %>
               Source: <%= chunk.sourceable.try(:title) || chunk.sourceable_id %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
