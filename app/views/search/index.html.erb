<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-indigo-700">PodSearch</h1>
    <%= link_to "Graph Explorer", knowledge_graph_index_path, class: "text-indigo-600 hover:text-indigo-800 font-medium flex items-center gap-1" %>
  </div>

  <%= form_with url: search_path, method: :post, local: true, class: "mb-8" do |f| %>
    <div class="flex gap-2">
      <%= f.text_field :q, 
          value: @query, 
          placeholder: "Ask something like 'How do I hire a PM?'", 
          class: "flex-grow p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:outline-none text-lg" %>
      
      <%= f.submit "Ask", 
          class: "bg-indigo-600 text-white px-6 py-3 rounded-lg hover:bg-indigo-700 transition font-medium text-lg cursor-pointer" %>
    </div>
  <% end %>

  <%= turbo_frame_tag "results" do %>
    <%= render "results" %>
  <% end %>
</div>
