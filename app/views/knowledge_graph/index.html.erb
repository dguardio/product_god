<div class="h-screen flex flex-col" data-controller="knowledge-graph">
  <!-- Header / Controls -->
  <div class="bg-white border-b border-gray-200 px-4 py-3 flex justify-between items-center z-10 shadow-sm">
    <div>
      <h1 class="text-xl font-bold text-gray-900">Knowledge Graph</h1>
      <p class="text-sm text-gray-500">Visualizing top connections from your data</p>
    </div>
    
    <div class="flex space-x-2 items-center">
      <!-- Scope Selector -->
      <select data-action="change->knowledge-graph#changeScope" class="block pl-3 pr-10 py-1.5 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md">
        <option value="all">Global Graph</option>
        <% if current_user %>
          <option value="mine">My Knowledge Graph</option>
        <% end %>
      </select>
      
      <button data-action="knowledge-graph#resetZoom" class="px-3 py-1.5 bg-gray-100 hover:bg-gray-200 rounded-md text-sm font-medium text-gray-700 transition-colors">
        Reset View
      </button>
      <%= link_to "Back to Dashboard", data_sources_path, class: "px-3 py-1.5 text-indigo-600 hover:text-indigo-800 text-sm font-medium" %>
    </div>
  </div>

  <!-- Graph Container -->
  <div id="cy" class="flex-grow bg-gray-50 relative w-full h-full">
    <!-- Loading State -->
    <div data-knowledge-graph-target="loader" class="absolute inset-0 flex items-center justify-center bg-white bg-opacity-75 z-20">
      <div class="flex flex-col items-center">
        <svg class="animate-spin h-10 w-10 text-indigo-600 mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <p class="text-gray-600 font-medium">Building Graph...</p>
      </div>
    </div>
    
    <!-- Info Panel (Drawer) -->
    <div data-knowledge-graph-target="infoPanel" class="hidden absolute top-4 right-4 w-80 bg-white rounded-lg shadow-xl border border-gray-200 p-4 z-30 transition-opacity">
      <div class="flex justify-between items-start mb-2">
        <h3 data-knowledge-graph-target="nodeTitle" class="text-lg font-bold text-gray-900">Node Name</h3>
        <button data-action="knowledge-graph#closePanel" class="text-gray-400 hover:text-gray-600">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <div class="mb-3">
        <span data-knowledge-graph-target="nodeType" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
          Type
        </span>
      </div>
      <p data-knowledge-graph-target="nodeDesc" class="text-sm text-gray-600 mb-4">Description goes here...</p>
      
      <div class="border-t pt-3">
        <button data-action="knowledge-graph#expandNode" class="w-full justify-center inline-flex items-center px-4 py-2 border border-blue-600 text-sm font-medium rounded-md text-blue-600 bg-white hover:bg-blue-50 focus:outline-none">
          Explore Neighbors
        </button>
      </div>
    </div>
  </div>
</div>
