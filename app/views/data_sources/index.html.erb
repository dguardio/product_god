<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="md:flex md:items-center md:justify-between mb-8">
    <div class="min-w-0 flex-1">
      <h2 class="text-3xl font-bold leading-7 text-indigo-900 sm:truncate sm:text-4xl sm:tracking-tight">Knowledge Base</h2>
      <p class="mt-2 text-lg text-indigo-700">Manage all your data sources for the Product God.</p>
    </div>
    <div class="mt-4 flex md:mt-0 md:ml-4">
      <%= link_to knowledge_graph_index_path, class: "ml-3 inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
        <svg class="-ml-1 mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        Visualize Graph
      <% end %>
    </div>
  </div>

  <!-- Upload Section -->
  <div class="bg-indigo-50 border border-indigo-100 rounded-xl p-6 mb-12">
    <h3 class="text-lg font-semibold text-indigo-900 mb-4">Add New Source</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      
      <!-- PDF Upload -->
      <div class="bg-white p-4 rounded-lg shadow-sm">
        <h4 class="font-medium text-gray-900 mb-2 flex items-center"><span class="mr-2">📄</span> PDF Document</h4>
        <%= form_with model: PdfDocument.new, url: create_pdf_data_sources_path, local: true do |f| %>
          <div class="space-y-3">
            <%= f.text_field :title, placeholder: "Title (e.g. Board Deck Q1)", class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            <%= f.file_field :file, class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
            <%= f.submit "Upload PDF", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none" %>
          </div>
        <% end %>
      </div>

      <!-- Slack Upload -->
      <div class="bg-white p-4 rounded-lg shadow-sm">
        <h4 class="font-medium text-gray-900 mb-2 flex items-center"><span class="mr-2">💬</span> Slack Export (Zip)</h4>
        <%= form_with model: SlackExport.new, url: create_slack_data_sources_path, local: true do |f| %>
          <div class="space-y-3">
            <%= f.text_field :title, placeholder: "Title (e.g. #product-dev)", class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            <%= f.file_field :file, accept: ".zip", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-pink-50 file:text-pink-700 hover:file:bg-pink-100" %>
            <%= f.submit "Import Slack", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-pink-600 hover:bg-pink-700 focus:outline-none" %>
          </div>
        <% end %>
      </div>

      <!-- Web Link -->
      <div class="bg-white p-4 rounded-lg shadow-sm">
        <h4 class="font-medium text-gray-900 mb-2 flex items-center"><span class="mr-2">🌐</span> Web Page</h4>
        <%= form_with model: WebPage.new, url: create_web_data_sources_path, local: true do |f| %>
          <div class="space-y-3">
            <%= f.text_field :title, placeholder: "Title (e.g. Competitor X Pricing)", class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            <%= f.url_field :url, placeholder: "https://example.com/page", class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            <%= f.submit "Fetch Page", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none" %>
          </div>
        <% end %>
      </div>

    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
      
      <!-- WhatsApp Upload (Reusing existing controller route) -->
      <div class="bg-white p-4 rounded-lg shadow-sm border border-green-100">
        <h4 class="font-medium text-gray-900 mb-2 flex items-center"><span class="mr-2">📱</span> WhatsApp Chat (.txt)</h4>
        <%= form_with model: WhatsAppChat.new, url: whats_app_chats_path, local: true do |f| %>
          <div class="space-y-3">
            <%= f.text_field :title, placeholder: "Title (e.g. Co-founder Chat)", class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            <%= f.file_field :file, accept: ".txt", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-green-50 file:text-green-700 hover:file:bg-green-100" %>
            <%= f.submit "Upload Chat", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none" %>
          </div>
        <% end %>
      </div>

       <!-- Podcast Manual Entry -->
       <!-- Assuming users might want to paste a transcript or upload a text file as an 'Episode' -->
       <!-- For MVP, we can treat it similar to PDF but mapped to Episode model if we want strict typing, 
            or just let them use PDF/Web for those. But user requested 'Podcast Transcripts'. 
            Let's allow creating an Episode with pasted content. -->
       <div class="bg-white p-4 rounded-lg shadow-sm border border-purple-100">
        <h4 class="font-medium text-gray-900 mb-2 flex items-center"><span class="mr-2">🎙️</span> Podcast Transcript</h4>
        <!-- We need a route for this. Let's add create_episode to DataSources for convenience -->
        <%= form_with scope: :episode, url: create_episode_data_sources_path, local: true do |f| %>
          <div class="space-y-3">
            <%= f.text_field :title, placeholder: "Episode Title", class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            <%= f.text_field :guest, placeholder: "Guest Name", class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
             <%= f.text_area :content, rows: 3, placeholder: "Paste transcript text here...", class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            <%= f.submit "Save Transcript", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-purple-600 hover:bg-purple-700 focus:outline-none" %>
          </div>
        <% end %>
      </div>
      
    </div>
  </div>

  <!-- Lists -->
  <div class="space-y-6">

    <!-- Podcast Episodes -->
    <details class="bg-white shadow overflow-hidden sm:rounded-md group" open>
      <summary class="px-4 py-5 sm:px-6 bg-gray-50 border-b border-gray-200 cursor-pointer flex justify-between items-center list-none outline-none focus:ring-2 focus:ring-indigo-500">
        <h3 class="text-lg leading-6 font-medium text-gray-900 flex items-center">
          <span class="mr-2">🎙️</span> Podcast Episodes
          <span class="ml-2 px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600"><%= @episodes.total_count %></span>
        </h3>
        <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
      </summary>
      
      <div class="border-t border-gray-200">
        <% if @episodes.any? %>
          <ul class="divide-y divide-gray-200">
            <% @episodes.each do |ep| %>
              <li class="px-4 py-4 flex items-center justify-between sm:px-6 hover:bg-gray-50">
                <div class="flex items-center min-w-0 flex-1">
                   <div class="text-sm font-medium text-purple-600 truncate mr-2"><%= ep.title %></div>
                   <span class="text-xs text-gray-500 truncate">w/ <%= ep.guest %></span>
                </div>
                <div class="ml-4 flex-shrink-0 flex items-center space-x-4">
                  <!-- Status: Inferred from chunks -->
                  <% if ep.content_chunks.any? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      Processed (<%= ep.content_chunks.count %>)
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                      Processing/Empty
                    </span>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
          <div class="px-4 py-3 border-t border-gray-200 bg-gray-50 sm:px-6">
            <%= paginate @episodes, param_name: :episodes_page %>
          </div>
        <% else %>
          <div class="px-4 py-8 text-center text-gray-500 text-sm">No episodes found.</div>
        <% end %>
      </div>
    </details>

    <!-- PDF Documents -->
    <details class="bg-white shadow overflow-hidden sm:rounded-md group">
      <summary class="px-4 py-5 sm:px-6 bg-gray-50 border-b border-gray-200 cursor-pointer flex justify-between items-center list-none outline-none focus:ring-2 focus:ring-indigo-500">
        <h3 class="text-lg leading-6 font-medium text-gray-900 flex items-center">
          <span class="mr-2">📄</span> PDF Documents
          <span class="ml-2 px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600"><%= @pdfs.total_count %></span>
        </h3>
        <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
      </summary>
      
      <div class="border-t border-gray-200">
        <% if @pdfs.any? %>
          <ul class="divide-y divide-gray-200">
            <% @pdfs.each do |pdf| %>
              <li class="px-4 py-4 flex items-center justify-between sm:px-6 hover:bg-gray-50">
                <div class="flex items-center min-w-0 flex-1">
                  <div class="text-sm font-medium text-indigo-600 truncate"><%= pdf.title %></div>
                </div>
                <div class="ml-4 flex-shrink-0 flex items-center space-x-4">
                  <% if pdf.content_chunks.any? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      Processed (<%= pdf.content_chunks.count %>)
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                      <svg class="animate-spin -ml-1 mr-1.5 h-3 w-3 text-gray-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                      </svg>
                      Queued
                    </span>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
          <div class="px-4 py-3 border-t border-gray-200 bg-gray-50 sm:px-6">
            <%= paginate @pdfs, param_name: :pdfs_page %>
          </div>
        <% else %>
          <div class="px-4 py-8 text-center text-gray-500 text-sm">No documents found.</div>
        <% end %>
      </div>
    </details>

    <!-- Slack Exports -->
    <details class="bg-white shadow overflow-hidden sm:rounded-md group">
      <summary class="px-4 py-5 sm:px-6 bg-gray-50 border-b border-gray-200 cursor-pointer flex justify-between items-center list-none outline-none focus:ring-2 focus:ring-indigo-500">
        <h3 class="text-lg leading-6 font-medium text-gray-900 flex items-center">
          <span class="mr-2">💬</span> Slack Exports
          <span class="ml-2 px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600"><%= @slacks.total_count %></span>
        </h3>
        <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
      </summary>
      
      <div class="border-t border-gray-200">
        <% if @slacks.any? %>
          <ul class="divide-y divide-gray-200">
            <% @slacks.each do |slack| %>
              <li class="px-4 py-4 flex items-center justify-between sm:px-6 hover:bg-gray-50">
                <div class="flex items-center min-w-0 flex-1">
                  <div class="text-sm font-medium text-pink-600 truncate"><%= slack.title %></div>
                </div>
                <div class="ml-4 flex-shrink-0 flex items-center space-x-4">
                  <% if slack.content_chunks.any? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      Processed (<%= slack.content_chunks.count %>)
                    </span>
                  <% else %>
                     <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                      Queued
                    </span>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
           <div class="px-4 py-3 border-t border-gray-200 bg-gray-50 sm:px-6">
            <%= paginate @slacks, param_name: :slacks_page %>
          </div>
        <% else %>
          <div class="px-4 py-8 text-center text-gray-500 text-sm">No Slack exports found.</div>
        <% end %>
      </div>
    </details>

    <!-- Web Pages -->
    <details class="bg-white shadow overflow-hidden sm:rounded-md group">
      <summary class="px-4 py-5 sm:px-6 bg-gray-50 border-b border-gray-200 cursor-pointer flex justify-between items-center list-none outline-none focus:ring-2 focus:ring-indigo-500">
        <h3 class="text-lg leading-6 font-medium text-gray-900 flex items-center">
          <span class="mr-2">🌐</span> Web Pages
          <span class="ml-2 px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600"><%= @webs.total_count %></span>
        </h3>
        <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
      </summary>
      
      <div class="border-t border-gray-200">
        <% if @webs.any? %>
          <ul class="divide-y divide-gray-200">
            <% @webs.each do |web| %>
              <li class="px-4 py-4 flex items-center justify-between sm:px-6 hover:bg-gray-50">
                <div class="flex items-center min-w-0 flex-1">
                  <div class="text-sm font-medium text-blue-600 truncate"><%= web.title %></div>
                  <div class="text-sm text-gray-500 ml-4 truncate max-w-xs"><%= web.url %></div>
                </div>
                <div class="ml-4 flex-shrink-0 flex items-center space-x-4">
                  <% if web.content_chunks.any? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      Processed (<%= web.content_chunks.count %>)
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                      Queued
                    </span>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
          <div class="px-4 py-3 border-t border-gray-200 bg-gray-50 sm:px-6">
            <%= paginate @webs, param_name: :webs_page %>
          </div>
        <% else %>
          <div class="px-4 py-8 text-center text-gray-500 text-sm">No web pages found.</div>
        <% end %>
      </div>
    </details>

    <!-- WhatsApp Chats -->
    <details class="bg-white shadow overflow-hidden sm:rounded-md group">
      <summary class="px-4 py-5 sm:px-6 bg-gray-50 border-b border-gray-200 cursor-pointer flex justify-between items-center list-none outline-none focus:ring-2 focus:ring-indigo-500">
        <h3 class="text-lg leading-6 font-medium text-gray-900 flex items-center">
          <span class="mr-2">📱</span> WhatsApp Chats
          <span class="ml-2 px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600"><%= @whatsapps.total_count %></span>
        </h3>
        <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
      </summary>
      
      <div class="border-t border-gray-200">
        <% if @whatsapps.any? %>
          <ul class="divide-y divide-gray-200">
            <% @whatsapps.each do |chat| %>
              <li class="px-4 py-4 flex items-center justify-between sm:px-6 hover:bg-gray-50">
                <div class="flex items-center min-w-0 flex-1">
                  <div class="text-sm font-medium text-green-600 truncate"><%= chat.title %></div>
                </div>
                <div class="ml-4 flex-shrink-0 flex items-center space-x-4">
                  <% if chat.processed? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      Processed (<%= chat.content_chunks.count %>)
                    </span>
                  <% else %>
                     <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                       <svg class="animate-spin -ml-1 mr-1.5 h-3 w-3 text-yellow-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                      </svg>
                      Processing...
                    </span>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
           <div class="px-4 py-3 border-t border-gray-200 bg-gray-50 sm:px-6">
            <%= paginate @whatsapps, param_name: :whatsapps_page %>
          </div>
        <% else %>
          <div class="px-4 py-8 text-center text-gray-500 text-sm">No chats found.</div>
        <% end %>
      </div>
    </details>

  </div>
</div>
