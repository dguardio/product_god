<!DOCTYPE html>
<html>
  <head>
    <title>ProductGod</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 text-gray-900 font-sans antialiased">
    <nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-md border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex">
            <div class="flex-shrink-0 flex items-center">
              <%= link_to root_path, class: "text-2xl font-black text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-600 tracking-tight" do %>
                product<span class="text-gray-900">god</span>
              <% end %>
            </div>
            <div class="hidden sm:ml-8 sm:flex sm:space-x-8">
              <%= link_to "Search", search_path, class: "border-transparent text-gray-500 hover:border-blue-500 hover:text-gray-900 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium transition-colors" %>
              <%= link_to "Graph Explorer", knowledge_graph_index_path, class: "border-transparent text-gray-500 hover:border-blue-500 hover:text-gray-900 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium transition-colors" %>
              <%= link_to "Playbooks", playbooks_path, class: "border-transparent text-gray-500 hover:border-blue-500 hover:text-gray-900 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium transition-colors" %>
              <%= link_to "Knowledge Base", data_sources_path, class: "border-transparent text-gray-500 hover:border-blue-500 hover:text-gray-900 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium transition-colors" %>
              <%= link_to "AI Chat", chat_sessions_path, class: "border-transparent text-gray-500 hover:border-blue-500 hover:text-gray-900 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium transition-colors" %>

            </div>
          </div>
          </div>
          <div class="hidden sm:ml-6 sm:flex sm:items-center">
            <% if user_signed_in? %>
              <span class="text-sm text-gray-500 mr-4"><%= current_user.email %></span>
              <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "text-gray-500 hover:text-gray-900 px-3 py-2 rounded-md text-sm font-medium" %>
            <% else %>
              <%= link_to "Sign in", new_user_session_path, class: "text-gray-500 hover:text-gray-900 px-3 py-2 rounded-md text-sm font-medium" %>
              <%= link_to "Sign up", new_user_registration_path, class: "text-white bg-blue-600 hover:bg-blue-700 px-3 py-2 rounded-md text-sm font-medium ml-2 transition-colors" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>
    </nav>
    <div class="container mx-auto mt-20 px-5">
      <% if notice %>
        <div class="mb-4 rounded-md bg-blue-50 p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3 flex-1 md:flex md:justify-between">
              <p class="text-sm text-blue-700"><%= notice %></p>
            </div>
          </div>
        </div>
      <% end %>
      <% if alert %>
        <div class="mb-4 rounded-md bg-red-50 p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3 flex-1 md:flex md:justify-between">
              <p class="text-sm text-red-700"><%= alert %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
    <main class="container mx-auto px-5 flex">
      <%= yield %>
    </main>
  </body>
</html>
