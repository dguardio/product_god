<div class="max-w-2xl mx-auto">
  <h1 class="text-3xl font-bold text-gray-900 mb-6">Upload WhatsApp Chat</h1>
  
  <div class="bg-white shadow sm:rounded-lg p-6">
    <%= form_with(model: @chat, local: true, class: "space-y-6") do |form| %>
      <% if @chat.errors.any? %>
        <div class="bg-red-50 p-4 rounded-md">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(@chat.errors.count, "error") %> prohibited this chat from being saved:
          </h3>
          <ul class="mt-2 list-disc pl-5 text-sm text-red-700">
            <% @chat.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= form.label :title, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.text_field :title, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md", placeholder: "e.g. Family Chat" %>
        </div>
      </div>

      <div>
        <%= form.label :file, "Export File (.txt)", class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.file_field :file, accept: ".txt", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
        </div>
        <p class="mt-2 text-sm text-gray-500">
          Export your chat from WhatsApp (without media) and upload the .txt file here.
        </p>
      </div>

      <div class="flex justify-end">
        <%= link_to "Cancel", whats_app_chats_path, class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 mr-3" %>
        <%= form.submit "Upload & Process", class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
      </div>
    <% end %>
  </div>
</div>
