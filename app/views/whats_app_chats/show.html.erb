<div class="space-y-6">
  <div class="flex justify-between items-center">
    <div>
      <%= link_to "← Back to Chats", whats_app_chats_path, class: "text-sm text-gray-500 hover:text-gray-900" %>
      <h1 class="text-3xl font-bold text-gray-900 mt-2"><%= @chat.title %></h1>
    </div>
    
    <% if @chat.processed? %>
      <span class="px-3 py-1 rounded-full bg-green-100 text-green-800 text-sm font-medium">Processed</span>
    <% else %>
      <span class="px-3 py-1 rounded-full bg-yellow-100 text-yellow-800 text-sm font-medium">Processing...</span>
    <% end %>
  </div>

  <div class="bg-white shadow sm:rounded-lg overflow-hidden">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg leading-6 font-medium text-gray-900">Content Chunks</h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">
        <%= @chat.content_chunks.count %> chunks generated.
      </p>
    </div>
    
    <div class="divide-y divide-gray-200">
      <% @chat.content_chunks.limit(50).each do |chunk| %>
        <div class="p-4 hover:bg-gray-50">
          <div class="text-xs text-gray-400 mb-1">ID: <%= chunk.id %> | Vector: <%= chunk.embedding.present? ? "Yes" : "No" %></div>
          <div class="text-sm text-gray-800 whitespace-pre-wrap font-mono bg-gray-50 p-2 rounded"><%= chunk.content.truncate(300) %></div>
        </div>
      <% end %>
    </div>
    
    <% if @chat.content_chunks.count > 50 %>
      <div class="p-4 bg-gray-50 text-center text-sm text-gray-500">
        Showing first 50 chunks...
      </div>
    <% end %>
  </div>
</div>
