<%= turbo_stream_from "board_meeting_#{@meeting.id}" %>

<div class="h-[calc(100vh-64px)] flex flex-col bg-slate-50 relative overflow-hidden">
  
  <!-- Header -->
  <div class="bg-white border-b border-gray-200 px-6 py-3 flex justify-between items-center z-10 shadow-sm">
    <div class="flex items-center space-x-4">
      <h1 class="text-lg font-bold text-gray-900 truncate max-w-xl"><%= @meeting.topic %></h1>
      <span class="px-2 py-0.5 rounded-full bg-green-100 text-green-800 text-xs font-bold uppercase tracking-wide">Live</span>
    </div>
    <div class="text-sm text-gray-500">
      Members: <span class="font-medium text-gray-800"><%= @guests.map(&:name).join(", ") %></span>
    </div>
  </div>

  <!-- Video Grid (Visuals) -->
  <div class="flex-none p-4 grid grid-cols-<%= @guests.count + 1 %> gap-4 h-48 sm:h-64 transition-all">
    <% @guests.each do |guest| %>
      <div class="relative bg-gray-800 rounded-xl overflow-hidden shadow-lg border border-gray-700 group">
        <!-- Placeholder for Video/Avatar -->
        <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-b from-gray-700 to-gray-900">
          <span class="text-4xl font-black text-gray-600 select-none"><%= guest.name.first %></span>
        </div>
        
        <!-- Name Label -->
        <div class="absolute bottom-2 left-2 bg-black/60 backdrop-blur-sm px-2 py-1 rounded text-white text-xs font-medium">
          <%= guest.name %>
        </div>
        
        <!-- Speaking Indicator (Pseudo) -->
        <!-- Logic to toggle this via Turbo/Stimulus later -->
        <div class="absolute top-2 right-2 w-3 h-3 bg-green-500 rounded-full shadow-lg border-2 border-gray-800 hidden group-hover:block"></div>
      </div>
    <% end %>
    
    <!-- User "Self View" -->
    <div class="relative bg-black rounded-xl overflow-hidden shadow-lg border border-gray-700">
       <div class="absolute inset-0 flex items-center justify-center">
          <span class="text-gray-500 text-sm">You</span>
       </div>
    </div>
  </div>

  <!-- Chat / Transcript -->
  <div class="flex-1 overflow-y-auto px-4 sm:px-8 py-4 space-y-4 custom-scrollbar" id="messages">
    <!-- Messages will be appended here -->
    <% @messages.each do |msg| %>
      <%= render "board_meetings/message", message: msg %>
    <% end %>
  </div>

  <div class="bg-white border-t border-gray-200 p-4 z-10">
    <div class="max-w-4xl mx-auto">
      <%= render "board_meetings/messages/form", meeting: @meeting %>
    </div>
  </div>
</div>
