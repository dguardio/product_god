<div class="max-w-7xl mx-auto py-8 text-center px-4">
  <h1 class="text-4xl font-extrabold text-gray-900 mb-4">Boardroom Simulator</h1>
  <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">Select your dream team of experts and simulate a high-stakes debate on any product topic.</p>

  <div class="bg-white shadow-lg rounded-2xl p-8 max-w-2xl mx-auto border border-gray-100 text-left">
    <%= form_with url: board_meetings_path, method: :post, local: true, class: "space-y-6" do |f| %>
      <div>
        <label for="topic" class="block text-sm font-medium text-gray-700 mb-1">Topic / Problem Statement</label>
        <%= f.text_field :topic, placeholder: "e.g., Should we move upmarket to Enterprise?", class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 py-3 px-4" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Select Board Members (2-3 recommended)</label>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 max-h-64 overflow-y-auto custom-scrollbar p-2 border border-gray-200 rounded-lg">
          <% @personas.each do |p| %>
            <div class="relative">
              <%= check_box_tag "guest_ids[]", p.id, false, id: "guest_#{p.id}", class: "peer sr-only" %>
              <label for="guest_<%= p.id %>" class="flex flex-col items-center p-3 cursor-pointer bg-white border border-gray-200 rounded-lg hover:bg-gray-50 peer-checked:border-blue-500 peer-checked:ring-1 peer-checked:ring-blue-500 peer-checked:bg-blue-50 transition-all">
                # Placeholder Avatar
                <div class="h-10 w-10 rounded-full bg-gradient-to-br from-gray-200 to-gray-300 mb-2 flex items-center justify-center text-xs font-bold text-gray-500">
                  <%= p.name.first(2).upcase %>
                </div>
                <span class="text-xs font-medium text-center text-gray-800"><%= p.name %></span>
              </label>
            </div>
          <% end %>
        </div>
      </div>

      <div class="pt-4">
        <%= f.submit "Start Meeting", class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
      </div>
    <% end %>
  </div>
</div>
