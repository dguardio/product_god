<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="text-center mb-12">
    <div class="inline-flex items-center justify-center p-4 bg-indigo-100 rounded-full mb-4">
      <span class="text-4xl">🧠</span>
    </div>
    <h1 class="text-4xl font-extrabold text-gray-900 sm:text-5xl md:text-6xl">
      <%= @user.username %>'s Knowledge Base
    </h1>
    <p class="mt-3 max-w-md mx-auto text-base text-gray-500 sm:text-lg md:mt-5 md:text-xl md:max-w-3xl">
      Explore the public inputs and insights curated by this user.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <!-- Podcast Episodes -->
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-2xl font-bold text-gray-900 mb-4 flex items-center">
        <span class="mr-2">🎙️</span> Podcasts
      </h2>
      <% if @episodes.any? %>
        <ul class="space-y-4">
          <% @episodes.each do |episode| %>
            <li class="border-b border-gray-100 pb-2 last:border-0 hover:bg-gray-50 p-2 rounded">
              <h3 class="font-semibold text-lg text-indigo-600"><%= episode.title %></h3>
              <p class="text-sm text-gray-500">Guest: <%= episode.guest %></p>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-gray-500 italic">No public episodes shared.</p>
      <% end %>
    </div>
    
    <!-- WhatsApp Chats -->
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-2xl font-bold text-gray-900 mb-4 flex items-center">
        <span class="mr-2">💬</span> Chats
      </h2>
      <% if @chats.any? %>
        <ul class="space-y-4">
          <% @chats.each do |chat| %>
            <li class="border-b border-gray-100 pb-2 last:border-0 hover:bg-gray-50 p-2 rounded">
              <h3 class="font-semibold text-lg text-indigo-600"><%= chat.title %></h3>
              <p class="text-sm text-gray-500">Shared <%= time_ago_in_words(chat.created_at) %> ago</p>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-gray-500 italic">No public chats shared.</p>
      <% end %>
    </div>
  </div>

  <!-- RAG Interaction Area -->
  <div class="mt-12 bg-indigo-50 border border-indigo-100 rounded-xl p-8 shadow-sm">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="text-2xl font-bold text-indigo-900 mb-4">Interrogate this Brain</h2>
      <p class="text-indigo-700 mb-6">Ask a question specifically about <%= @user.username %>'s public knowledge.</p>
      
      <%= form_with url: search_path, method: :post, local: true, class: "relative" do |form| %>
        <%= form.text_field :q, class: "w-full rounded-full border-indigo-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 py-3 px-6 text-lg", placeholder: "What did #{ @user.username } share about...?" %>
        <%= form.hidden_field :scope_user_id, value: @user.id %>
        <button type="submit" class="absolute right-2 top-2 bg-indigo-600 text-white rounded-full p-2 hover:bg-indigo-700 transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>
      <% end %>
    </div>
  </div>
</div>
